generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          String    @default("user")
  phone         String?
  avatar        String?
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  isActive      Boolean   @default(true)
  isFrozen      Boolean   @default(false)
  lastLoginAt   DateTime?
  lastLoginIp   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  notifications Notification[]
  savingsGoals  SavingsGoal[]
  adminLogs     AdminLog[]    @relation("AdminLogs")
  fraudAlerts   FraudAlert[]
  refreshTokens RefreshToken[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Account {
  id            String   @id @default(cuid())
  userId        String
  accountNumber String   @unique
  type          String   @default("checking")
  balance       Float    @default(0)
  currency      String   @default("USD")
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTransactions     Transaction[] @relation("FromAccount")
  receivedTransactions Transaction[] @relation("ToAccount")

  @@index([userId])
  @@index([accountNumber])
}

model Transaction {
  id              String   @id @default(cuid())
  fromAccountId   String?
  toAccountId     String?
  amount          Float
  type            String
  category        String   @default("other")
  status          String   @default("completed")
  description     String?
  reference       String   @unique @default(cuid())
  metadata        String?
  isFlagged       Boolean  @default(false)
  createdAt       DateTime @default(now())

  fromAccount     Account? @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount       Account? @relation("ToAccount", fields: [toAccountId], references: [id])
  fraudAlert      FraudAlert?

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([createdAt])
  @@index([status])
}

model SavingsGoal {
  id            String   @id @default(cuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float    @default(0)
  deadline      DateTime?
  status        String   @default("active")
  icon          String   @default("piggy-bank")
  color         String   @default("#4361EE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  severity  String   @default("info")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin      User     @relation("AdminLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
}

model FraudAlert {
  id            String      @id @default(cuid())
  userId        String
  transactionId String?     @unique
  riskScore     Float
  reason        String
  status        String      @default("open")
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id])
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@index([userId])
  @@index([status])
}
